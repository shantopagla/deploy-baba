# Example Terraform variables file for deploy-baba
# Copy this to terraform.tfvars and customize for your environment

project_name = "deploy-baba"
region       = "us-east-1"
environment  = "prod"

# Lambda configuration
lambda_memory  = 256    # MB
lambda_timeout = 30     # seconds

# Backup configuration
backup_schedule        = "rate(1 day)"
backup_retain_versions = 7

# Path to built Lambda zip file (relative to this directory)
lambda_code_path = "./build/lambda.zip"

# CloudWatch Logs retention
logs_retention_days = 14
